# Environment Variables Template
# Copy this file to .env.local and fill in the values

# Database (Postgres everywhere - use Neon connection string for both local and production)
# For local dev: Create a free Neon database at https://neon.tech
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Payload CMS
PAYLOAD_SECRET=your-secret-key-here

# Email Service (Resend)
RESEND_API_KEY=

# GitHub Integration
GITHUB_TOKEN=

# Observability (Axiom via next-axiom)
# Create free account at https://axiom.co
# Token: Settings → API Tokens → Create with "Ingest" permission
# Dataset: Datasets → Create (e.g., "personal-website")
# NOTE: NEXT_PUBLIC_ prefix required for client-side web vitals
NEXT_PUBLIC_AXIOM_TOKEN=
NEXT_PUBLIC_AXIOM_DATASET=

# Cron Job Security
CRON_SECRET=
