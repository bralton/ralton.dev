{
  "ci": {
    "collect": {
      "startServerCommand": "npm run start",
      "startServerReadyPattern": "Ready in",
      "url": [
        "http://localhost:3000",
        "http://localhost:3000/blog",
        "http://localhost:3000/blog/getting-started-with-nextjs",
        "http://localhost:3000/blog/category/technology"
      ],
      "numberOfRuns": 1,
      "settings": {
        "onlyCategories": ["accessibility", "seo"],
        "chromeFlags": "--no-sandbox --disable-gpu --headless"
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.9 }],

        "color-contrast": "error",
        "bypass": "error",
        "document-title": "error",
        "duplicate-id-aria": "error",
        "html-has-lang": "error",
        "html-lang-valid": "error",
        "image-alt": "error",
        "link-name": "error",
        "button-name": "error",
        "form-field-multiple-labels": "warn",
        "frame-title": "error",
        "heading-order": "warn",
        "label": "error",
        "landmark-one-main": "warn",
        "listitem": "error",
        "meta-viewport": "error",
        "tabindex": "error",
        "valid-lang": "error",
        "aria-allowed-attr": "error",
        "aria-hidden-body": "error",
        "aria-hidden-focus": "error",
        "aria-required-attr": "error",
        "aria-required-children": "error",
        "aria-required-parent": "error",
        "aria-roles": "error",
        "aria-valid-attr-value": "error",
        "aria-valid-attr": "error",

        "meta-description": "error",
        "link-text": "warn",
        "crawlable-anchors": "warn",
        "is-crawlable": "error",
        "robots-txt": "warn",
        "canonical": "error"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
